        <Param val="if ((response.keys === null)) {&amp;#10;    fbText = &quot;No response detected.&quot;;&amp;#10;    fbColor = &quot;yellow&quot;;&amp;#10;} else {&amp;#10;    if (response.corr) {&amp;#10;        fbText = &quot;Correct!&quot;;&amp;#10;        fbColor = &quot;limegreen&quot;;&amp;#10;    } else {&amp;#10;        fbText = &quot;Incorrect&quot;;&amp;#10;        fbColor = &quot;red&quot;;&amp;#10;    }&amp;#10;}&amp;#10;psychoJS.experiment.addData(&quot;DEBUG_TargetType&quot;, TargetType);&amp;#10;psychoJS.experiment.addData(&quot;DEBUG_correctKey&quot;, correctKey);&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
